generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== CONFIGURACIÓN FRIGORÍFICO ====================

model ConfiguracionFrigorifico {
  id                      String   @id @default(cuid())
  nombre                  String   @default("Solemar Alimentaria")
  direccion               String?
  numeroEstablecimiento   String?  // N° Establecimiento Oficial
  cuit                    String?
  numeroMatricula         String?  // N° Matrícula
  logo                    String?  // URL del logo (logo.png)
  
  // Configuración de emails
  emailHost               String?  // smtp.office365.com
  emailPuerto             Int?     @default(587)
  emailUsuario            String?  // usuario@solemar.com.ar
  emailPassword           String?  // Encriptado
  emailHabilitado         Boolean  @default(false)
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ==================== CORRALES ====================

model Corral {
  id          String   @id @default(cuid())
  nombre      String   @unique
  capacidad   Int      @default(0)
  observaciones String?
  activo      Boolean  @default(true)
  
  // Stock actual
  stockBovinos  Int    @default(0)
  stockEquinos  Int    @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  movimientosOrigen   MovimientoCorral[]  @relation("CorralOrigen")
  movimientosDestino  MovimientoCorral[]  @relation("CorralDestino")
  tropas              Tropa[]
}

// ==================== CÁMARAS ====================

model Camara {
  id            String        @id @default(cuid())
  nombre        String        @unique
  tipo          TipoCamara    @default(FAENA)
  capacidad     Int           @default(0)  // Ganchos o KG según tipo
  observaciones String?
  activo        Boolean       @default(true)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  movimientosOrigen   MovimientoCamara[]  @relation("CamaraOrigen")
  movimientosDestino  MovimientoCamara[]  @relation("CamaraDestino")
  stockMedias         StockMediaRes[]
  mediasRes           MediaRes[]
  stockSIGICA         StockCamaraSIGICA?
}

enum TipoCamara {
  FAENA      // Capacidad en ganchos
  CUARTEO    // Capacidad en KG
  DEPOSITO   // Capacidad en KG
}

// ==================== TIPIFICADORES ====================

model Tipificador {
  id            String   @id @default(cuid())
  nombre        String
  apellido      String
  numero        String?  // Número interno
  matricula     String   @unique  // Número de matrícula (se usa en rótulos)
  activo        Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  romaneos      Romaneo[]
}

// ==================== PRODUCTOS ====================

model Producto {
  id                    String          @id @default(cuid())
  codigo                String          // Código de artículo (3 dígitos)
  nombre                String
  nombreReportes        String?
  especie               Especie
  
  // Configuración del código EAN-128 (parte fija)
  codigoTipificacion    String?         // 2 dígitos
  codigoTipoTrabajo     String?         // 1 dígito
  codigoTransporte      String?         // 1 dígito
  codigoDestino         String?         // 2 dígitos
  
  // Datos del producto
  tara                  Float?
  diasConservacion      Int?
  requiereTipificacion  Boolean         @default(false)
  tipoRotulo            TipoRotulo?
  precio                Float?
  temperaturaConservacion String?
  
  // Reportes
  apareceRendimiento    Boolean         @default(false)
  apareceStock          Boolean         @default(false)
  
  activo                Boolean         @default(true)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@unique([codigo, especie])
  @@index([especie])
}

// ==================== SUBPRODUCTOS ====================

model Subproducto {
  id                String        @id @default(cuid())
  codigo            String        // Código interno
  nombre            String
  descripcion       String?
  
  // Categorización
  categoria         String?       // Menudencia, Cuero, Sebo, etc.
  tipo              String?       // Tipo específico
  
  // Precios y costos
  precioKg          Float?
  costoProcesamiento Float?
  
  // Trazabilidad
  requiereTrazabilidad Boolean    @default(false)
  
  // Stock
  unidadMedida      String        @default("KG")  // KG, UN
  stockMinimo       Float?
  
  activo            Boolean       @default(true)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  @@unique([codigo])
}

enum TipoRotulo {
  MEDIA_RES
  CUARTO
  MENUDENCIA
  PRODUCTO_TERMINADO_ENVASE_PRIMARIO
  PRODUCTO_TERMINADO_ENVASE_SECUNDARIO
  PRODUCTO_TERMINADO_UN_ENVASE
}

// ==================== TIPOS DE MENUDENCIAS ====================

model TipoMenudencia {
  id            String   @id @default(cuid())
  nombre        String   @unique
  activo        Boolean  @default(true)
  observaciones String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  menudencias   Menudencia[]
}

// ==================== OPERADORES ====================

model Operador {
  id            String   @id @default(cuid())
  nombre        String
  usuario       String   @unique
  password      String   // Hash de la contraseña
  pin           String?  // PIN numérico opcional
  rol           RolOperador @default(OPERADOR)
  email         String?
  activo        Boolean  @default(true)
  
  // Control de contraseña
  passwordChangedAt  DateTime?
  passwordMustChange Boolean @default(false)
  failedLoginAttempts Int    @default(0)
  lockedUntil        DateTime?
  
  // Permisos detallados
  puedePesajeCamiones     Boolean @default(true)
  puedePesajeIndividual   Boolean @default(true)
  puedeMovimientoHacienda Boolean @default(true)
  puedeListaFaena         Boolean @default(false)
  puedeRomaneo            Boolean @default(false)
  puedeIngresoCajon       Boolean @default(false)
  puedeMenudencias        Boolean @default(false)
  puedeStock              Boolean @default(false)
  puedeReportes           Boolean @default(false)
  puedeCCIR               Boolean @default(false)
  puedeFacturacion        Boolean @default(false)
  puedeConfiguracion      Boolean @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relaciones
  pesajesCamion        PesajeCamion[]
  pesajesIndividuales  PesajeIndividual[]
  tropasCreadas        Tropa[]
  listasFaena          ListaFaena[]
  romaneos             Romaneo[]
  movimientosCorral    MovimientoCorral[]
  movimientosCamara    MovimientoCamara[]
  auditorias           Auditoria[]
  facturas             Factura[]
  ccirs                CCIR[]
  declaracionesJuradas DeclaracionJurada[]
  sesiones             Sesion[]
  intentosLogin        IntentoLogin[]
  ipsBloqueadas        IpBloqueada[]
  
  // Relaciones para Flujo Faena
  flujosVerificados    FlujoFaena[]    @relation("VerificadorFlujo")
  flujosSupervisados   FlujoFaena[]    @relation("SupervisorFlujo")
  historialFlujos      HistorialFlujoFaena[]
  
  // SIGICA
  enviosSIGICA         EnvioSIGICA[]
}

enum RolOperador {
  OPERADOR
  SUPERVISOR
  ADMINISTRADOR
}

// ==================== USUARIOS (Clientes que usan el servicio de faena) ====================

model Usuario {
  id              String   @id @default(cuid())
  nombre          String
  cuit            String?  @unique
  direccion       String?
  telefono        String?
  email           String?
  
  // Tipos de usuario (puede ser más de uno)
  esUsuarioFaena  Boolean  @default(false)  // Usa servicio de faena
  esProductor     Boolean  @default(false)  // Es productor de hacienda
  esConsignatario Boolean  @default(false)  // Es consignatario
  esProveedor     Boolean  @default(false)  // Es proveedor
  
  // Datos adicionales
  observaciones   String?
  activo          Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relaciones
  tropasComoProductor    Tropa[]    @relation("ProductorTropas")
  tropasComoUsuarioFaena Tropa[]    @relation("UsuarioFaenaTropas")
  facturas               Factura[]
  declaracionesJuradas   DeclaracionJurada[]
  notasCredito           NotaCredito[]
  notasDebito            NotaDebito[]
}

// ==================== PRODUCTORES / CONSIGNATARIOS ====================

model ProductorConsignatario {
  id              String   @id @default(cuid())
  nombre          String
  cuit            String?  @unique
  direccion       String?
  telefono        String?
  email           String?
  
  // Tipo
  tipo            String   @default("PRODUCTOR")  // PRODUCTOR, CONSIGNATARIO, AMBOS
  
  // Datos RENSPA (para productores)
  numeroRenspa    String?
  numeroEstablecimiento String?
  localidad       String?
  provincia       String?
  
  // Datos adicionales
  observaciones   String?
  activo          Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== PROVEEDORES ====================

model Proveedor {
  id              String   @id @default(cuid())
  nombre          String
  cuit            String?  @unique
  direccion       String?
  telefono        String?
  email           String?
  
  // Tipo de proveedor
  tipo            String?  // Insumos, Servicios, Equipos, etc.
  
  // Datos adicionales
  contacto        String?
  observaciones   String?
  activo          Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  insumos          Insumo[]
  ordenesCompra    OrdenCompra[]
}

// ==================== TRANSPORTISTAS ====================

model Transportista {
  id        String   @id @default(cuid())
  nombre    String
  cuit      String?  @unique
  direccion String?
  telefono  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  pesajes   PesajeCamion[]
}

// ==================== TABLAS DE CÓDIGOS ====================

model CodigoEspecie {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "1", "2", "6", etc.
  nombre      String            // "equino", "bovino", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTransporte {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "0", "1", "2", etc.
  nombre      String            // "BARCO enfriado", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoDestino {
  id          String   @id @default(cuid())
  codigo      String   @unique  // ".00", ".01", etc.
  nombre      String            // "Italia", "Francia", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTipoTrabajo {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "0", "1", "2", etc.
  nombre      String            // "Ninguna", "descarte", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTipificacion {
  id          String   @id @default(cuid())
  codigo      String   @unique  // ".00", ".01", ".02", etc.
  nombre      String            // "todas", "M", "A", etc.
  especie     Especie           // Para qué especie aplica
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TROPAS ====================

model Tropa {
  id              String      @id @default(cuid())
  numero          Int         @unique
  codigo          String      @unique   // Formato: "B 2026 0001" o "E 2026 0001"
  codigoSimplificado String?            // "B0001" para rótulos
  
  // Origen de los animales
  productorId     String?
  productor       Usuario?    @relation("ProductorTropas", fields: [productorId], references: [id])
  usuarioFaenaId  String
  usuarioFaena    Usuario     @relation("UsuarioFaenaTropas", fields: [usuarioFaenaId], references: [id])
  
  especie         Especie     @default(BOVINO)
  
  // Documentos de tránsito (OBLIGATORIOS)
  dte             String
  guia            String
  
  // Cantidad total
  cantidadCabezas Int
  
  // Tipos de animales (detalle)
  tiposAnimales   TropaAnimalCantidad[]
  
  // Corral asignado
  corralId        String?
  corral          Corral?     @relation(fields: [corralId], references: [id])
  
  // Estado
  estado          EstadoTropa @default(RECIBIDO)
  
  // Pesos (del pesaje de camión)
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  
  // Pesaje individual (suma de animales pesados)
  pesoTotalIndividual Float?
  
  observaciones   String?
  fechaRecepcion  DateTime    @default(now())
  
  // Operador que registró
  operadorId      String?
  operador        Operador?   @relation(fields: [operadorId], references: [id])
  
  // Relación con pesaje de camión
  pesajeCamionId  String?     @unique
  pesajeCamion    PesajeCamion?  @relation(fields: [pesajeCamionId], references: [id])
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  animales        Animal[]
  listasFaena     ListaFaenaTropa[]
  balancesFaena   BalanceFaena[]
  
  @@index([especie])
  @@index([estado])
  @@index([fechaRecepcion])
}

// Detalle de tipos de animales por tropa
model TropaAnimalCantidad {
  id          String   @id @default(cuid())
  tropaId     String
  tropa       Tropa    @relation(fields: [tropaId], references: [id], onDelete: Cascade)
  tipoAnimal  TipoAnimal
  cantidad    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([tropaId, tipoAnimal])
}

enum Especie {
  BOVINO
  EQUINO
}

enum TipoAnimal {
  // Bovinos
  TO    // Toro
  VA    // Vaca
  VQ    // Vaquillona
  MEJ   // Torito/Mej
  NO    // Novillo
  NT    // Novillito
  
  // Equinos
  PADRILLO
  POTRILLO
  YEGUA
  CABALLO
  BURRO
  MULA
}

enum EstadoTropa {
  RECIBIDO
  EN_CORRAL
  EN_PESAJE
  PESADO
  LISTO_FAENA
  EN_FAENA
  FAENADO
  DESPACHADO
}

// ==================== ANIMALES ====================

model Animal {
  id             String       @id @default(cuid())
  tropaId        String
  tropa          Tropa        @relation(fields: [tropaId], references: [id])
  
  numero         Int          // Número secuencial dentro de la tropa
  codigo         String       @unique // Código completo: B20260001-001
  
  // Identificación
  caravana       String?      // Número de caravana/arete
  tipoAnimal     TipoAnimal
  raza           String?      // Raza del animal (Angus, Hereford, etc.)
  
  pesoVivo       Float?       // Peso en pie (del pesaje individual)
  
  estado         EstadoAnimal @default(RECIBIDO)
  corralId       String?      // Corral actual (para movimientos)
  
  // Baja/Fallecimiento
  fechaBaja      DateTime?
  motivoBaja     String?
  pesoBaja       Float?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  pesajeIndividual PesajeIndividual?
  asignacionGarron  AsignacionGarron?
  
  @@unique([tropaId, numero])
  @@index([estado])
}

enum EstadoAnimal {
  RECIBIDO
  PESADO
  EN_FAENA
  FAENADO
  EN_CAMARA
  DESPACHADO
  FALLECIDO
}

// ==================== MOVIMIENTOS DE CORRAL ====================

model MovimientoCorral {
  id            String   @id @default(cuid())
  tropaId       String?
  animalId      String?
  
  corralOrigenId  String?
  corralOrigen    Corral?  @relation("CorralOrigen", fields: [corralOrigenId], references: [id])
  corralDestinoId String
  corralDestino   Corral   @relation("CorralDestino", fields: [corralDestinoId], references: [id])
  
  cantidad      Int      @default(1)
  especie       Especie?
  observaciones String?
  
  operadorId    String?
  operador      Operador? @relation(fields: [operadorId], references: [id])
  
  fecha         DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([fecha])
}

// ==================== PESAJE CAMIÓN ====================

model PesajeCamion {
  id              String          @id @default(cuid())
  tipo            TipoPesajeCamion @default(INGRESO_HACIENDA)
  numeroTicket    Int             @unique
  
  // Datos del vehículo
  patenteChasis   String
  patenteAcoplado String?
  
  // Chofer
  choferNombre    String?
  choferDni       String?
  
  // Transportista
  transportistaId String?
  transportista   Transportista?  @relation(fields: [transportistaId], references: [id])
  
  // Para Ingreso de Hacienda
  tropa           Tropa?
  
  // Para Salida de Mercadería
  destino         String?
  remito          String?
  factura         String?
  precintos       String?         // Números de precinto separados por coma
  
  // Pesos
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  
  // Para pesaje particular
  observaciones   String?
  
  // Estado
  estado          EstadoPesaje    @default(ABIERTO)
  
  // Operador
  operadorId      String?
  operador        Operador?       @relation(fields: [operadorId], references: [id])
  
  fecha           DateTime        @default(now())
  fechaTara       DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([tipo])
  @@index([estado])
  @@index([fecha])
}

enum TipoPesajeCamion {
  INGRESO_HACIENDA
  PESAJE_PARTICULAR
  SALIDA_MERCADERIA
}

enum EstadoPesaje {
  ABIERTO
  CERRADO
  ANULADO
}

// ==================== PESAJE INDIVIDUAL ====================

model PesajeIndividual {
  id            String     @id @default(cuid())
  animalId      String     @unique
  animal        Animal     @relation(fields: [animalId], references: [id])
  
  peso          Float
  caravana      String?    // Si se lee automáticamente
  observaciones String?
  
  operadorId    String?
  operador      Operador?  @relation(fields: [operadorId], references: [id])
  
  fecha         DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  @@index([fecha])
}

// ==================== LISTA DE FAENA ====================

model ListaFaena {
  id            String          @id @default(cuid())
  fecha         DateTime        @default(now())  // Una por día
  estado        EstadoListaFaena @default(ABIERTA)
  
  cantidadTotal Int             @default(0)
  
  supervisorId  String?         // Quien cierra la lista
  supervisor    Operador?       @relation(fields: [supervisorId], references: [id])
  fechaCierre   DateTime?
  
  observaciones String?
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  tropas        ListaFaenaTropa[]
  asignaciones  AsignacionGarron[]
  flujoFaena    FlujoFaena?
  
  @@index([fecha])
  @@index([estado])
}

model ListaFaenaTropa {
  id            String   @id @default(cuid())
  listaFaenaId  String
  listaFaena    ListaFaena @relation(fields: [listaFaenaId], references: [id], onDelete: Cascade)
  
  tropaId       String
  tropa         Tropa    @relation(fields: [tropaId], references: [id])
  
  cantidad      Int      // Cantidad de animales de esta tropa a faenar
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([listaFaenaId, tropaId])
}

enum EstadoListaFaena {
  ABIERTA
  EN_PROCESO
  CERRADA
  ANULADA
}

// ==================== ASIGNACIÓN DE GARRÓN ====================

model AsignacionGarron {
  id            String       @id @default(cuid())
  listaFaenaId  String
  listaFaena    ListaFaena   @relation(fields: [listaFaenaId], references: [id])
  
  garron        Int          // Número de garrón (correlativo por día)
  
  animalId      String       @unique
  animal        Animal       @relation(fields: [animalId], references: [id])
  
  // Datos al momento de la asignación (se pueden modificar)
  numeroAnimal  Int          // Número del animal dentro de la tropa
  
  // Hora de ingreso a faena
  horaIngreso   DateTime     @default(now())
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@unique([listaFaenaId, garron])
  @@index([garron])
}

// ==================== ROMANEO ====================

model Romaneo {
  id                String        @id @default(cuid())
  listaFaenaId      String?
  fecha             DateTime      @default(now())
  
  // Datos del animal
  garron            Int
  tropaCodigo       String?
  numeroAnimal      Int?
  tipoAnimal        TipoAnimal?
  raza              String?
  pesoVivo          Float?        // KG ingreso
  
  // Tipificación
  denticion        String?        // Cantidad de dientes
  tipificadorId    String?
  tipificador      Tipificador?  @relation(fields: [tipificadorId], references: [id])
  
  // Pesos de medias reses
  pesoMediaIzq      Float?
  pesoMediaDer      Float?
  pesoTotal         Float?        // Suma de ambas medias
  
  // Rinde
  rinde             Float?        // Porcentaje
  
  // Estado
  estado            EstadoRomaneo @default(PENDIENTE)
  supervisorId      String?       // Quien confirma
  fechaConfirmacion DateTime?
  emailEnviado      Boolean       @default(false)
  
  operadorId        String?
  operador          Operador?     @relation(fields: [operadorId], references: [id])
  
  observaciones     String?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  mediasRes         MediaRes[]
  
  @@index([fecha])
  @@index([garron])
  @@index([estado])
}

enum EstadoRomaneo {
  PENDIENTE
  CONFIRMADO
  ANULADO
}

// ==================== MEDIAS RESES ====================

model MediaRes {
  id            String       @id @default(cuid())
  romaneoId     String
  romaneo       Romaneo      @relation(fields: [romaneoId], references: [id])
  
  lado          LadoMedia    // IZQUIERDA o DERECHA
  peso          Float
  sigla         SiglaMedia   @default(A)  // A, T, D
  
  // Código de barras
  codigo        String       @unique
  
  // Estado
  estado        EstadoMediaRes @default(EN_CAMARA)
  
  // Cámara
  camaraId      String?
  camara        Camara?      @relation(fields: [camaraId], references: [id])
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@unique([romaneoId, lado, sigla])
  @@index([estado])
}

enum LadoMedia {
  IZQUIERDA
  DERECHA
}

enum SiglaMedia {
  A   // Asado
  T   // Trasero
  D   // Delantero
}

enum EstadoMediaRes {
  EN_CAMARA
  EN_CUARTEO
  DESPACHADO
}

// ==================== STOCK CÁMARA ====================

model StockMediaRes {
  id            String   @id @default(cuid())
  camaraId      String
  camara        Camara   @relation(fields: [camaraId], references: [id])
  
  tropaCodigo   String?
  especie       Especie
  
  cantidad      Int      @default(0)
  pesoTotal     Float    @default(0)
  
  fechaIngreso  DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([camaraId, tropaCodigo, especie])
}

// ==================== MOVIMIENTOS DE CÁMARA ====================

model MovimientoCamara {
  id              String   @id @default(cuid())
  
  camaraOrigenId  String?
  camaraOrigen    Camara?  @relation("CamaraOrigen", fields: [camaraOrigenId], references: [id])
  camaraDestinoId String?
  camaraDestino   Camara?  @relation("CamaraDestino", fields: [camaraDestinoId], references: [id])
  
  producto        String?  // Qué se movió
  cantidad        Int?
  peso            Float?
  
  // Trazabilidad
  tropaCodigo     String?
  mediaResId      String?
  
  operadorId      String?
  operador        Operador? @relation(fields: [operadorId], references: [id])
  
  observaciones   String?
  fecha           DateTime @default(now())
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([fecha])
}

// ==================== MENUDENCIAS ====================

model Menudencia {
  id                String           @id @default(cuid())
  tipoMenudenciaId  String
  tipoMenudencia    TipoMenudencia   @relation(fields: [tipoMenudenciaId], references: [id])
  
  tropaCodigo       String?
  
  // Pesos
  pesoIngreso       Float?           // KG al ingresar a cámara
  pesoElaborado     Float?           // KG después de elaboración
  
  // Bolsas
  numeroBolsa       Int?
  cantidadBolsas    Int?
  
  // Operadores
  operadorElaboracion String?
  
  fechaIngreso      DateTime         @default(now())
  fechaElaboracion  DateTime?
  
  // Rótulo
  rotuloImpreso     Boolean          @default(false)
  
  observaciones     String?
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  @@index([tropaCodigo])
  @@index([fechaIngreso])
}

// ==================== AUDITORÍA ====================

model Auditoria {
  id            String   @id @default(cuid())
  operadorId    String?
  operador      Operador? @relation(fields: [operadorId], references: [id])
  
  modulo        String
  submodulo     String?
  accion        String   // CREATE, UPDATE, DELETE, READ, LOGIN, LOGOUT, EXPORT
  entidad       String
  entidadId     String?
  entidadNombre String?  // Nombre legible de la entidad
  
  descripcion   String
  datosAntes    String?  // JSON
  datosDespues  String?  // JSON
  cambios       String?  // Solo campos modificados (JSON)
  
  fecha         DateTime @default(now())
  ip            String?
  userAgent     String?
  
  // Contexto adicional
  sessionId     String?
  dispositivo   String?
  
  @@index([modulo])
  @@index([accion])
  @@index([entidad])
  @@index([fecha])
  @@index([operadorId])
}

// ==================== SESIONES ====================

model Sesion {
  id            String   @id @default(cuid())
  operadorId    String
  operador      Operador @relation(fields: [operadorId], references: [id])
  
  token         String   @unique
  fechaInicio   DateTime @default(now())
  fechaExpiracion DateTime
  ultimaActividad DateTime @default(now())
  
  ip            String?
  userAgent     String?
  dispositivo   String?
  
  activa        Boolean  @default(true)
  fechaCierre   DateTime?
  motivoCierre  String?  // LOGOUT, EXPIRED, FORCED, SECURITY
  
  @@index([operadorId])
  @@index([token])
  @@index([fechaExpiracion])
}

// ==================== CONFIGURACIÓN DE SEGURIDAD ====================

model ConfiguracionSeguridad {
  id                          String   @id @default(cuid())
  
  // Política de contraseñas
  passwordMinLength           Int      @default(8)
  passwordRequireUppercase    Boolean  @default(true)
  passwordRequireLowercase    Boolean  @default(true)
  passwordRequireNumbers      Boolean  @default(true)
  passwordRequireSpecialChars Boolean  @default(false)
  passwordMaxAge              Int      @default(90)  // días
  
  // Sesión
  sessionTimeout              Int      @default(480)  // minutos (8 horas)
  maxConcurrentSessions       Int      @default(1)
  
  // Intentos de login
  maxLoginAttempts            Int      @default(5)
  lockoutDuration             Int      @default(30)  // minutos
  
  // Notificaciones de seguridad
  notifyNewIp                 Boolean  @default(true)
  notifyFailedAttempts        Boolean  @default(true)
  notifyPasswordChange        Boolean  @default(true)
  notifyOutOfHoursAccess      Boolean  @default(false)
  
  // Horario permitido (opcional)
  restrictedHoursEnabled      Boolean  @default(false)
  allowedHourStart            Int?
  allowedHourEnd              Int?
  
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

// ==================== BLOQUEOS DE IP ====================

model IpBloqueada {
  id            String   @id @default(cuid())
  ip            String
  motivo        String   // BRUTE_FORCE, MANUAL, SUSPICIOUS_ACTIVITY
  fechaBloqueo  DateTime @default(now())
  fechaExpiracion DateTime?
  activo        Boolean  @default(true)
  operadorId    String?  // Si fue bloqueado manualmente
  operador      Operador? @relation(fields: [operadorId], references: [id])
  
  @@index([ip])
  @@index([activo])
}

// ==================== INTENTOS DE LOGIN FALLIDOS ====================

model IntentoLogin {
  id            String   @id @default(cuid())
  ip            String
  usuario       String?  // Usuario intentado
  operadorId    String?  // Si el usuario existe
  operador      Operador? @relation(fields: [operadorId], references: [id])
  exitoso       Boolean
  motivo        String?  // USUARIO_NO_EXISTE, PASSWORD_INCORRECTO, BLOQUEADO, etc.
  fecha         DateTime @default(now())
  userAgent     String?
  
  @@index([ip])
  @@index([fecha])
}

// ==================== NUMERADORES ====================

model Numerador {
  id            String   @id @default(cuid())
  nombre        String   @unique  // "TROPA_BOVINO", "TROPA_EQUINO", "TICKET", etc.
  ultimoNumero  Int      @default(0)
  anio          Int?
  
  updatedAt     DateTime @updatedAt
}

// ==================== CCIR - Certificado de Calidad e Inspección Retirada ====================

model CCIR {
  id                    String        @id @default(cuid())
  numeroCertificado     String        @unique  // Número único del certificado
  fechaEmision          DateTime      @default(now())
  
  // Datos del producto
  producto              String        // Descripción del producto
  cantidad              Float         // Cantidad en KG
  lote                  String?       // Lote/tropa de origen
  
  // Destino
  paisDestino           String        // País de destino de la exportación
  puertoDestino         String?       // Puerto de destino
  
  // Datos del establecimiento
  numeroEstablecimiento String?       // N° de establecimiento habilitado
  nombreEstablecimiento String?       // Nombre del establecimiento
  cuitEstablecimiento   String?       // CUIT del establecimiento
  
  // Datos del importador (opcional)
  nombreImportador      String?
  direccionImportador   String?
  
  // Contenedor/Transporte
  numeroContenedor      String?
  matriculaTransporte   String?
  
  // Precintos
  numeroPrecintos       String?       // Números de precintos separados por coma
  
  // Observaciones
  observaciones         String?
  
  // Estado
  estado                EstadoCCIR    @default(EMITIDO)
  
  // Operador que generó
  operadorId            String?
  operador              Operador?     @relation(fields: [operadorId], references: [id])
  
  // Fechas de impresión
  fechaImpresion        DateTime?
  vecesImpreso          Int           @default(0)
  
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  @@index([fechaEmision])
  @@index([estado])
  @@index([paisDestino])
}

enum EstadoCCIR {
  EMITIDO
  ANULADO
  EXPORTADO
}

// ==================== DECLARACIÓN JURADA ====================

model DeclaracionJurada {
  id                    String              @id @default(cuid())
  numeroDeclaracion     String              @unique  // Número único de declaración
  fecha                 DateTime            @default(now())
  
  // Datos del productor
  productorId           String?
  productor             Usuario?            @relation(fields: [productorId], references: [id])
  nombreProductor       String              // Nombre del productor (denormalizado)
  cuitProductor         String?             // CUIT del productor
  direccionProductor    String?             // Dirección del productor
  
  // Datos del origen
  procedencia           String?             // Lugar de procedencia de los animales
  
  // Datos de la especie
  especie               Especie             @default(BOVINO)
  
  // Cantidad
  cantidadCabezas       Int                 // Cantidad de animales
  
  // Identificación de tropa/lote
  numeroTropa          String?             // Número de tropa
  numeroLote           String?             // Número de lote
  
  // Documentos de origen
  numeroDTE            String?             // Documento de Tránsito Electrónico
  numeroGuia           String?             // Guía de tránsito
  
  // Declaración de sanidad
  declaracionSanidad   String?             // Texto de la declaración
  procedenciaLibre     Boolean             @default(true)  // Si proviene de zona libre
  
  // Observaciones
  observaciones        String?
  
  // Estado
  estado               EstadoDeclaracionJurada  @default(ACTIVA)
  
  // Operador que generó
  operadorId           String?
  operador             Operador?           @relation(fields: [operadorId], references: [id])
  
  // Fechas de impresión
  fechaImpresion       DateTime?
  vecesImpreso         Int                 @default(0)
  
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  
  @@index([fecha])
  @@index([estado])
  @@index([especie])
}

enum EstadoDeclaracionJurada {
  ACTIVA
  ANULADA
  UTILIZADA
}

// ==================== FACTURACIÓN ====================

model Factura {
  id                String        @id @default(cuid())
  numero            String        @unique  // N° de factura (ej: 0001-00001234)
  numeroInterno     Int                    // Número secuencial interno
  
  // Cliente/Usuario
  clienteId         String
  cliente           Usuario       @relation(fields: [clienteId], references: [id])
  
  // Fechas
  fecha             DateTime      @default(now())
  fechaEmision      DateTime?     // Cuando se emitió
  fechaPago         DateTime?     // Cuando se pagó
  
  // Totales
  subtotal          Float         @default(0)
  iva               Float         @default(0)
  total             Float         @default(0)
  
  // Estado
  estado            EstadoFactura @default(PENDIENTE)
  
  // Observaciones
  observaciones     String?
  
  // Datos adicionales
  condicionVenta    String?       // Contado, Cuenta Corriente, etc.
  remito            String?       // N° de remito asociado
  
  // Operador
  operadorId        String?
  operador          Operador?     @relation(fields: [operadorId], references: [id])
  
  // Datos AFIP
  cae               String?       // Código de Autorización Electrónico
  caeVencimiento    DateTime?     // Fecha de vencimiento del CAE
  tipoComprobante   Int?          // 1=FA, 6=FB, 11=FC, etc.
  puntoVenta        Int?          // Punto de venta AFIP
  numeroAfip        Int?          // Número de comprobante en AFIP
  
  // Moneda y cotización
  monedaId          String?
  moneda            Moneda?       @relation(fields: [monedaId], references: [id])
  cotizacionId      String?       // ID de la cotización al momento de la factura
  cotizacion        Float?        // Cotización usada (valor denormalizado para histórico)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  detalles          DetalleFactura[]
  pagosAplicados    PagoFactura[]
  
  @@index([numero])
  @@index([clienteId])
  @@index([estado])
  @@index([fecha])
  @@index([cae])
}

model DetalleFactura {
  id                String        @id @default(cuid())
  facturaId         String
  factura           Factura       @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  
  // Producto facturado
  tipoProducto      TipoProductoFactura  // MEDIA_RES, CUARTO, MENUDENCIA, OTRO
  descripcion       String                // Descripción del producto
  
  // Cantidad y precio
  cantidad          Float         @default(1)
  unidad            String        @default("KG")  // KG, UN
  precioUnitario    Float         @default(0)
  subtotal          Float         @default(0)
  
  // Trazabilidad (opcional)
  tropaCodigo       String?       // Código de tropa
  garron            Int?          // Número de garrón
  mediaResId        String?       // ID de media res
  
  // Datos del animal/producto
  pesoKg            Float?        // Peso en KG
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  @@index([facturaId])
  @@index([tipoProducto])
}

enum EstadoFactura {
  PENDIENTE         // Creada pero no emitida
  EMITIDA           // Emitida al cliente
  PAGADA            // Pagada por el cliente
  ANULADA           // Anulada
}

enum TipoProductoFactura {
  MEDIA_RES         // Media res completa
  CUARTO_DELANTERO  // Cuarto delantero
  CUARTO_TRASERO    // Cuarto trasero
  MENUDENCIA        // Menudencias
  OTRO              // Otros productos
}

// ==================== BALANZAS ====================

model Balanza {
  id              String        @id @default(cuid())
  nombre          String        // "Balanza Camiones", "Balanza Romaneo", etc.
  descripcion     String?

  // Configuración RS232
  puerto          String        // COM1, COM3, /dev/ttyUSB0, etc.
  baudios         Int           @default(9600)
  dataBits        Int           @default(8)
  stopBits        Int           @default(1)
  paridad         String        @default("none")  // none, odd, even

  // Protocolo
  protocolo       ProtocoloBalanza @default(CONTINUO)
  comandoPeso     String?       // Comando para solicitar peso (si es bajo demanda)
  formatoTrama    String?       // Formato de la trama recibida

  // Configuración de lectura
  tiempoEstabilidad Int         @default(2000)  // ms para considerar estable
  decimales       Int           @default(1)     // Cantidad de decimales

  // Uso
  uso             UsoBalanza    @default(CAMIONES)

  // Estado
  activa          Boolean       @default(true)
  ultimaConexion  DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum ProtocoloBalanza {
  CONTINUO        // Envía peso constantemente
  BAJO_DEMANDA    // Responde solo cuando se solicita
}

enum UsoBalanza {
  CAMIONES        // Balanza de camiones
  ROMANEO         // Balanza de romaneo/playa
  INDIVIDUAL      // Balanza de pesaje individual
  MENUDENCIAS     // Balanza de menudencias
}

// ==================== IMPRESORAS ====================

model Impresora {
  id              String        @id @default(cuid())
  nombre          String        // "Impresora Rótulos", "Impresora Tickets", etc.
  descripcion     String?

  // Configuración de impresora
  tipo            TipoImpresora @default(TERMICA)
  modelo          String?       // Modelo específico
  direccion       String?       // IP, puerto, o nombre de impresora compartida

  // Dimensiones de etiqueta (mm)
  anchoEtiqueta   Int           @default(100)
  altoEtiqueta    Int           @default(50)
  margenSuperior  Int           @default(2)
  margenIzquierdo Int           @default(2)
  margenDerecho   Int           @default(2)
  margenInferior  Int           @default(2)

  // Configuración de impresión
  dpi             Int           @default(203)
  velocidad       Int           @default(2)  // pulgadas/segundo
  densidad        Int           @default(8)  // nivel de oscuridad

  // Uso
  uso             UsoImpresora  @default(ROTULOS)

  // Estado
  activa          Boolean       @default(true)
  porDefecto      Boolean       @default(false)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum TipoImpresora {
  TERMICA         // Impresora térmica de etiquetas
  INYECCION       // Impresora de inyección de tinta
  LASER           // Impresora láser
  MATRICIAL       // Impresora matricial
  TERMICA_TICKET  // Impresora térmica de tickets
}

enum UsoImpresora {
  ROTULOS         // Rótulos de medias res
  TICKETS         // Tickets de pesaje
  FACTURAS        // Facturas y remitos
  REPORTES        // Reportes generales
}

// ==================== INSUMOS Y MATERIALES ====================

model CategoriaInsumo {
  id            String   @id @default(cuid())
  nombre        String   @unique
  descripcion   String?
  activo        Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  insumos       Insumo[]
}

model Insumo {
  id                  String            @id @default(cuid())
  codigo              String            @unique
  nombre              String
  descripcion         String?
  
  // Categorización
  categoriaId         String?
  categoria           CategoriaInsumo?  @relation(fields: [categoriaId], references: [id])
  
  // Datos del insumo
  unidadMedida        String            @default("UN")  // UN, KG, LT, M, M2, M3
  marca               String?
  modelo              String?
  
  // Precios y costos
  precioUnitario      Float?
  costoUnitario       Float?
  
  // Stock
  stockMinimo         Float?
  stockMaximo         Float?
  puntoReposicion     Float?
  
  // Proveedor principal
  proveedorId         String?
  proveedor           Proveedor?        @relation(fields: [proveedorId], references: [id])
  codigoProveedor     String?           // Código del insumo en el proveedor
  
  // Control
  requiereLote        Boolean           @default(false)
  requiereVencimiento Boolean           @default(false)
  
  activo              Boolean           @default(true)
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  stockPorDeposito    StockInsumo[]
  movimientos         MovimientoInsumo[]
  lotes               LoteInsumo[]
  consumos            ConsumoInsumo[]
  ordenesCompra       DetalleOrdenCompra[]
  detallesInventario  DetalleInventario[]
  
  @@index([categoriaId])
  @@index([proveedorId])
}

model Deposito {
  id              String   @id @default(cuid())
  nombre          String   @unique
  descripcion     String?
  ubicacion       String?
  responsable     String?
  
  // Capacidad
  capacidadM2     Float?
  capacidadM3     Float?
  
  activo          Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  stockInsumos    StockInsumo[]
  movimientosOrigen   MovimientoInsumo[] @relation("DepositoOrigen")
  movimientosDestino  MovimientoInsumo[] @relation("DepositoDestino")
  inventarios      Inventario[]
}

model StockInsumo {
  id              String    @id @default(cuid())
  insumoId        String
  insumo          Insumo    @relation(fields: [insumoId], references: [id])
  
  depositoId      String
  deposito        Deposito  @relation(fields: [depositoId], references: [id])
  
  // Cantidad actual
  cantidad        Float     @default(0)
  cantidadMinima  Float?
  cantidadMaxima  Float?
  
  // Valorización
  precioPromedio  Float?
  valorTotal      Float?
  
  // Último movimiento
  ultimoIngreso   DateTime?
  ultimaSalida    DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([insumoId, depositoId])
  @@index([insumoId])
  @@index([depositoId])
}

model LoteInsumo {
  id              String    @id @default(cuid())
  insumoId        String
  insumo          Insumo    @relation(fields: [insumoId], references: [id])
  
  codigo          String    // Código del lote
  cantidadInicial Float
  cantidadActual  Float     @default(0)
  
  // Fechas
  fechaIngreso    DateTime  @default(now())
  fechaVencimiento DateTime?
  
  // Costo
  costoUnitario   Float?
  
  // Origen
  ordenCompraId   String?
  numeroRemito    String?
  
  activo          Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([insumoId, codigo])
  @@index([insumoId])
  @@index([fechaVencimiento])
}

model MovimientoInsumo {
  id                String              @id @default(cuid())
  insumoId          String
  insumo            Insumo              @relation(fields: [insumoId], references: [id])
  
  // Tipo de movimiento
  tipo              TipoMovimientoInsumo
  
  // Depósitos
  depositoOrigenId  String?
  depositoOrigen    Deposito?           @relation("DepositoOrigen", fields: [depositoOrigenId], references: [id])
  depositoDestinoId String?
  depositoDestino   Deposito?           @relation("DepositoDestino", fields: [depositoDestinoId], references: [id])
  
  // Cantidad
  cantidad          Float
  
  // Lote (opcional)
  loteInsumoId      String?
  
  // Costo
  precioUnitario    Float?
  costoTotal        Float?
  
  // Documento origen
  documentoTipo     String?   // REMITO, FACTURA, ORDEN_INTERNA, AJUSTE
  documentoNumero   String?
  
  // Centro de costo (opcional)
  centroCostoId     String?
  
  // Producción (opcional)
  produccionId      String?   // Si está asociado a una producción
  
  observaciones     String?
  
  operadorId        String?
  
  fecha             DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([insumoId])
  @@index([tipo])
  @@index([fecha])
}

enum TipoMovimientoInsumo {
  INGRESO           // Entrada por compra
  EGRESO            // Salida por consumo
  TRANSFERENCIA     // Entre depósitos
  AJUSTE_POSITIVO   // Ajuste de inventario (+)
  AJUSTE_NEGATIVO   // Ajuste de inventario (-)
  DEVOLUCION        // Devolución a proveedor
  PERDIDA           // Pérdida/desperdicio
}

// ==================== ÓRDENES DE COMPRA ====================

model OrdenCompra {
  id              String              @id @default(cuid())
  numero          Int                 @unique
  
  // Proveedor
  proveedorId     String?
  proveedor       Proveedor?          @relation(fields: [proveedorId], references: [id])
  
  // Fechas
  fechaEmision    DateTime            @default(now())
  fechaEntrega    DateTime?
  fechaRecepcion  DateTime?
  
  // Estado
  estado          EstadoOrdenCompra   @default(PENDIENTE)
  
  // Totales
  subtotal        Float               @default(0)
  iva             Float               @default(0)
  total           Float               @default(0)
  
  // Observaciones
  observaciones   String?
  
  // Operador
  operadorId      String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  detalles        DetalleOrdenCompra[]
  recepciones     RecepcionCompra[]
  
  @@index([proveedorId])
  @@index([estado])
  @@index([fechaEmision])
}

model DetalleOrdenCompra {
  id              String        @id @default(cuid())
  ordenCompraId   String
  ordenCompra     OrdenCompra   @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  
  // Insumo
  insumoId        String
  insumo          Insumo        @relation(fields: [insumoId], references: [id])
  
  // Cantidad
  cantidadPedida  Float
  cantidadRecibida Float        @default(0)
  
  // Precios
  precioUnitario  Float
  subtotal        Float
  
  // Estado
  estado          EstadoDetalleOrden @default(PENDIENTE)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([ordenCompraId])
  @@index([insumoId])
}

model RecepcionCompra {
  id              String          @id @default(cuid())
  ordenCompraId   String
  ordenCompra     OrdenCompra     @relation(fields: [ordenCompraId], references: [id])
  
  // Datos de recepción
  numeroRemito    String?
  fechaRecepcion  DateTime        @default(now())
  
  // Estado
  estado          EstadoRecepcion @default(PARCIAL)
  
  observaciones   String?
  
  operadorId      String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([ordenCompraId])
}

enum EstadoOrdenCompra {
  PENDIENTE       // Creada, esperando aprobación
  APROBADA        // Aprobada, esperando envío
  ENVIADA         // Enviada por proveedor
  PARCIAL         // Recepción parcial
  COMPLETADA      // Recepción completa
  ANULADA         // Anulada
}

enum EstadoDetalleOrden {
  PENDIENTE
  PARCIAL
  COMPLETADO
}

enum EstadoRecepcion {
  PARCIAL
  COMPLETA
}

// ==================== CENTROS DE COSTO ====================

model CentroCosto {
  id              String    @id @default(cuid())
  codigo          String    @unique
  nombre          String
  descripcion     String?
  
  // Tipo
  tipo            String    // PRODUCCION, ADMINISTRACION, LOGISTICA, MANTENIMIENTO
  
  // Responsable
  responsable     String?
  
  // Presupuesto
  presupuestoMensual Float?
  
  activo          Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  presupuestos    PresupuestoCentro[]
  consumos        ConsumoCentro[]
  consumosInsumo  ConsumoInsumo[]
  balancesFaena   BalanceFaena[]
  balancesInsumos BalanceInsumos[]
}

model PresupuestoCentro {
  id              String      @id @default(cuid())
  centroCostoId   String
  centroCosto     CentroCosto @relation(fields: [centroCostoId], references: [id])
  
  // Período
  anio            Int
  mes             Int
  
  // Montos
  presupuesto     Float
  ejecutado       Float       @default(0)
  desviacion      Float?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@unique([centroCostoId, anio, mes])
  @@index([centroCostoId])
}

model ConsumoCentro {
  id              String      @id @default(cuid())
  centroCostoId   String
  centroCosto     CentroCosto @relation(fields: [centroCostoId], references: [id])
  
  // Período
  fecha           DateTime    @default(now())
  
  // Concepto
  concepto        String
  categoria       String?     // INSUMOS, PERSONAL, SERVICIOS, EQUIPOS
  
  // Montos
  cantidad        Float?
  monto           Float
  
  observaciones   String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([centroCostoId])
  @@index([fecha])
}

// ==================== CONSUMO DE INSUMOS ====================

model ConsumoInsumo {
  id              String        @id @default(cuid())
  insumoId        String
  insumo          Insumo        @relation(fields: [insumoId], references: [id])
  
  // Centro de costo
  centroCostoId   String?
  centroCosto     CentroCosto?  @relation(fields: [centroCostoId], references: [id])
  
  // Cantidad
  cantidad        Float
  
  // Costo
  costoUnitario   Float?
  costoTotal      Float?
  
  // Producción asociada
  tropaId         String?
  produccionFecha DateTime?
  cantidadProducida Float?    // KG producidos
  
  // Eficiencia
  consumoEstandar Float?      // Lo que debería haber consumido
  desviacion      Float?      // Diferencia con el estándar
  
  observaciones   String?
  
  fecha           DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([insumoId])
  @@index([centroCostoId])
  @@index([fecha])
}

// ==================== FORMAS DE PAGO Y CAJAS ====================

model FormaPago {
  id              String          @id @default(cuid())
  nombre          String          @unique
  descripcion     String?
  
  // Tipo
  tipo            TipoFormaPago
  
  // Configuración
  requiereBanco   Boolean         @default(false)
  requiereCheque  Boolean         @default(false)
  requiereTarjeta Boolean         @default(false)
  
  // Contabilidad
  cuentaContable  String?
  
  activo          Boolean         @default(true)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  pagos           Pago[]
}

enum TipoFormaPago {
  EFECTIVO
  CHEQUE_AL_DIA
  CHEQUE_DIFERIDO
  TRANSFERENCIA
  TARJETA_CREDITO
  TARJETA_DEBITO
  RETENCION
  COMPENSACION
  OTRO
}

model Caja {
  id              String    @id @default(cuid())
  nombre          String    @unique
  descripcion     String?
  
  // Tipo
  tipo            String    // GENERAL, CHICA, BANCO
  
  // Responsable
  responsable     String?
  
  // Saldo
  saldoActual     Float     @default(0)
  saldoInicial    Float     @default(0)
  
  // Cuenta bancaria (si aplica)
  cuentaBancariaId String?
  
  activo          Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  movimientos     MovimientoCaja[]
  arqueos         ArqueoCaja[]
}

model MovimientoCaja {
  id              String          @id @default(cuid())
  cajaId          String
  caja            Caja            @relation(fields: [cajaId], references: [id])
  
  // Tipo
  tipo            TipoMovimientoCaja
  
  // Monto
  monto           Float
  saldoAnterior   Float
  saldoNueva      Float
  
  // Documento origen
  documentoTipo   String?         // FACTURA, RECIBO, PAGO, TRANSFERENCIA
  documentoId     String?
  documentoNumero String?
  
  // Concepto
  concepto        String
  observaciones   String?
  
  // Tercero
  terceroNombre   String?
  terceroCuit     String?
  
  operadorId      String?
  
  fecha           DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  detallesConciliacion DetalleConciliacion[]
  
  @@index([cajaId])
  @@index([tipo])
  @@index([fecha])
}

enum TipoMovimientoCaja {
  INGRESO
  EGRESO
  TRANSFERENCIA_ENTRADA
  TRANSFERENCIA_SALIDA
  APERTURA
  CIERRE
  AJUSTE
}

model ArqueoCaja {
  id              String    @id @default(cuid())
  cajaId          String
  caja            Caja      @relation(fields: [cajaId], references: [id])
  
  // Fecha
  fecha           DateTime  @default(now())
  
  // Saldos
  saldoSistema    Float     // Lo que el sistema dice
  saldoFisico     Float     // Lo que se contó
  diferencia      Float     // Diferencia
  
  // Estado
  estado          String    @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  
  observaciones   String?
  
  operadorId      String?
  supervisorId    String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([cajaId])
  @@index([fecha])
}

model CuentaBancaria {
  id              String    @id @default(cuid())
  banco           String
  tipoCuenta      String    // CAJA_AHORRO, CUENTA_CORRIENTE
  numeroCuenta    String
  cbu             String?
  alias           String?
  
  // Saldo
  saldoActual     Float     @default(0)
  saldoConciliado Float     @default(0)
  
  // Datos adicionales
  titular         String?
  cuitTitular     String?
  
  activo          Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  cheques         Cheque[]
  conciliaciones  ConciliacionBancaria[]
  
  @@unique([cbu])
}

model Cheque {
  id                String          @id @default(cuid())
  numero            String
  banco             String
  
  // Monto
  monto             Float
  
  // Fechas
  fechaEmision      DateTime        @default(now())
  fechaVencimiento  DateTime
  fechaCobro        DateTime?
  
  // Origen
  cuentaBancariaId  String?
  cuentaBancaria    CuentaBancaria? @relation(fields: [cuentaBancariaId], references: [id])
  
  // Librador
  libradorNombre    String
  libradorCuit      String?
  libradorTelefono  String?
  
  // Estado
  estado            EstadoCheque    @default(RECIBIDO)
  
  // Destino
  destino           String?         // BANCO, PROVEEDOR, etc.
  
  observaciones     String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  pagos             Pago[]
  
  @@unique([numero, banco])
  @@index([estado])
  @@index([fechaVencimiento])
}

enum EstadoCheque {
  RECIBIDO        // Recibido de cliente
  DEPOSITADO      // Depositado en banco
  COBRADO         // Cobrado
  ENTREGADO       // Entregado a proveedor
  RECHAZADO       // Rechazado por falta de fondos
  ANULADO         // Anulado
}

model Pago {
  id              String        @id @default(cuid())
  numero          Int           @unique
  
  // Cliente/Proveedor
  terceroId       String?
  terceroNombre   String
  terceroCuit     String?
  terceroTipo     String        // CLIENTE, PROVEEDOR
  
  // Forma de pago
  formaPagoId     String?
  formaPago       FormaPago?    @relation(fields: [formaPagoId], references: [id])
  
  // Monto
  monto           Float
  
  // Moneda y cotización
  monedaId        String?
  moneda          Moneda?       @relation(fields: [monedaId], references: [id])
  cotizacionId    String?       // ID de la cotización al momento del pago
  cotizacion      Float?        // Cotización usada (valor denormalizado para histórico)
  
  // Cheque (si aplica)
  chequeId        String?
  cheque          Cheque?       @relation(fields: [chequeId], references: [id])
  
  // Fechas
  fecha           DateTime      @default(now())
  
  // Estado
  estado          EstadoPago    @default(PENDIENTE)
  
  // Documento
  comprobante     String?
  
  observaciones   String?
  
  operadorId      String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  aplicaciones    PagoFactura[]
  
  @@index([terceroId])
  @@index([estado])
  @@index([fecha])
}

model PagoFactura {
  id              String    @id @default(cuid())
  pagoId          String
  pago            Pago      @relation(fields: [pagoId], references: [id], onDelete: Cascade)
  
  facturaId       String
  factura         Factura   @relation(fields: [facturaId], references: [id])
  
  // Monto aplicado
  monto           Float
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([pagoId, facturaId])
  @@index([pagoId])
  @@index([facturaId])
}

enum EstadoPago {
  PENDIENTE
  CONFIRMADO
  ANULADO
}

// ==================== BALANCES Y RENDIMIENTOS ====================

model BalanceFaena {
  id              String      @id @default(cuid())
  tropaId         String?
  tropa           Tropa?      @relation(fields: [tropaId], references: [id])
  
  // Período
  fecha           DateTime    @default(now())
  
  // Entrada
  pesoVivoTotal   Float       @default(0)
  cantidadCabezas Int         @default(0)
  
  // Salida
  pesoFrioTotal   Float       @default(0)
  cantidadMedias  Int         @default(0)
  
  // Rendimiento
  rindePromedio   Float?
  rindeMinimo     Float?
  rindeMaximo     Float?
  
  // Menudencias
  pesoMenudencias Float?
  
  // Pérdidas
  pesoMerma       Float?
  porcentajeMerma Float?
  
  // Centro de costo
  centroCostoId   String?
  centroCosto     CentroCosto? @relation(fields: [centroCostoId], references: [id])
  
  observaciones   String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([fecha])
  @@index([tropaId])
}

model RendimientoHistorico {
  id              String    @id @default(cuid())
  
  // Período
  anio            Int
  mes             Int
  
  // Especie
  especie         Especie
  
  // Tipo animal
  tipoAnimal      TipoAnimal
  
  // Estadísticas
  cantidadAnimales  Int     @default(0)
  pesoVivoPromedio  Float?
  pesoFrioPromedio  Float?
  rindePromedio     Float?
  rindeMinimo       Float?
  rindeMaximo       Float?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([anio, mes, especie, tipoAnimal])
  @@index([especie])
}

model BalanceInsumos {
  id              String    @id @default(cuid())
  
  // Período
  fechaDesde      DateTime
  fechaHasta      DateTime
  
  // Centro de costo
  centroCostoId   String?
  centroCosto     CentroCosto? @relation(fields: [centroCostoId], references: [id])
  
  // Consumo total
  consumoTotal    Float     @default(0)
  
  // Producción
  kgProducidos    Float     @default(0)
  cabezasFaenadas Int       @default(0)
  
  // Indicadores
  costoPorKg      Float?
  costoPorCabeza  Float?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([fechaDesde])
}

model Indicador {
  id              String    @id @default(cuid())
  codigo          String    @unique
  nombre          String
  descripcion     String?
  
  // Unidad
  unidad          String    // %, KG, $
  
  // Meta
  meta            Float?
  alertaMinima    Float?
  alertaMaxima    Float?
  
  // Categoría
  categoria       String    // RENDIMIENTO, COSTO, PRODUCCION, FINANCIERO
  
  activo          Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  valores         ValorIndicador[]
}

model ValorIndicador {
  id              String      @id @default(cuid())
  indicadorId     String
  indicador       Indicador   @relation(fields: [indicadorId], references: [id])
  
  // Período
  fecha           DateTime
  
  // Valor
  valor           Float
  valorMeta       Float?
  desviacion      Float?
  
  observaciones   String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@unique([indicadorId, fecha])
  @@index([indicadorId])
  @@index([fecha])
}

// ==================== NOTAS DE CRÉDITO Y DÉBITO ====================

model NotaCredito {
