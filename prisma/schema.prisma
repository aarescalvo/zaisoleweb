  cantidad        Float         @default(1)
  precioUnitario  Float         @default(0)
  subtotal        Float         @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([notaCreditoId])
}

model NotaDebito {
  id              String          @id @default(cuid())
  numero          String          @unique
  numeroInterno   Int
  
  // Cliente
  clienteId       String
  cliente         Usuario         @relation(fields: [clienteId], references: [id])
  
  // Factura asociada
  facturaId       String?
  
  // Fechas
  fecha           DateTime        @default(now())
  
  // Montos
  subtotal        Float           @default(0)
  iva             Float           @default(0)
  total           Float           @default(0)
  
  // Motivo
  motivo          String
  observaciones   String?
  
  // Estado
  estado          EstadoNota      @default(EMITIDA)
  
  operadorId      String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  detalles        DetalleNotaDebito[]
  
  @@index([clienteId])
  @@index([fecha])
}

model DetalleNotaDebito {
  id              String        @id @default(cuid())
  notaDebitoId    String
  notaDebito      NotaDebito    @relation(fields: [notaDebitoId], references: [id], onDelete: Cascade)
  
  descripcion     String
  cantidad        Float         @default(1)
  precioUnitario  Float         @default(0)
  subtotal        Float         @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([notaDebitoId])
}

enum EstadoNota {
  EMITIDA
  APLICADA
  ANULADA
}

// ==================== INVENTARIOS ====================

model Inventario {
  id              String            @id @default(cuid())
  numero          Int               @unique
  
  // Depósito
  depositoId      String
  deposito        Deposito          @relation(fields: [depositoId], references: [id])
  
  // Fechas
  fechaInicio     DateTime          @default(now())
  fechaFin        DateTime?
  
  // Estado
  estado          EstadoInventario  @default(PENDIENTE)
  
  // Resultados
  itemsTotal      Int               @default(0)
  itemsConDiferencia Int            @default(0)
  valorDiferencia Float?
  
  observaciones   String?
  
  operadorId      String?
  supervisorId    String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  detalles        DetalleInventario[]
  
  @@index([depositoId])
  @@index([estado])
}

model DetalleInventario {
  id              String      @id @default(cuid())
  inventarioId    String
  inventario      Inventario  @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  
  // Insumo
  insumoId        String
  insumo          Insumo      @relation(fields: [insumoId], references: [id])
  
  // Cantidades
  cantidadSistema Float       // Lo que dice el sistema
  cantidadFisica  Float       // Lo que se contó
  diferencia      Float       // Diferencia
  
  // Costo
  costoUnitario   Float?
  costoDiferencia Float?
  
  // Estado
  estado          String      @default("PENDIENTE") // PENDIENTE, AJUSTADO
  
  observaciones   String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@unique([inventarioId, insumoId])
  @@index([inventarioId])
}

enum EstadoInventario {
  PENDIENTE
  EN_PROCESO
  COMPLETADO
  AJUSTADO
}

// ==================== CONFIGURACIÓN AFIP ====================

model AFIPConfig {
  id                String   @id @default(cuid())
  
  // Certificados
  certificado       String?  // Contenido del certificado .pem (base64)
  clavePrivada      String?  // Contenido de la clave privada .key (base64)
  
  // Configuración
  puntoVenta        Int      @default(1)
  ambiente          String   @default("testing") // testing, production
  
  // Validación
  certificadoValido Boolean  @default(false)
  fechaVencimiento  DateTime?
  
  // Última conexión
  ultimoToken       DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ==================== CONCILIACIÓN BANCARIA ====================

model ConciliacionBancaria {
  id              String    @id @default(cuid())
  cuentaBancariaId String
  cuentaBancaria  CuentaBancaria @relation(fields: [cuentaBancariaId], references: [id])
  
  fecha           DateTime  @default(now())
  fechaDesde      DateTime
  fechaHasta      DateTime
  
  // Archivo importado
  nombreArchivo   String
  totalRegistros  Int
  totalDebitos    Float     @default(0)
  totalCreditos   Float     @default(0)
  
  // Resultados
  conciliados     Int       @default(0)
  pendientes      Int       @default(0)
  diferencias     Int       @default(0)
  
  estado          String    @default("PENDIENTE") // PENDIENTE, PROCESADA, CONFIRMADA
  
  creadoPor       String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  detalles        DetalleConciliacion[]
  
  @@index([cuentaBancariaId])
  @@index([fecha])
}

model DetalleConciliacion {
  id                  String    @id @default(cuid())
  conciliacionId      String
  conciliacion        ConciliacionBancaria @relation(fields: [conciliacionId], references: [id], onDelete: Cascade)
  
  // Datos del extracto bancario
  fechaExtracto       DateTime
  descripcionExtracto String
  referenciaExtracto  String?
  montoExtracto       Float
  tipoExtracto        String    // DEBITO, CREDITO
  
  // Datos del sistema (si se concilió)
  movimientoCajaId    String?
  movimientoCaja      MovimientoCaja? @relation(fields: [movimientoCajaId], references: [id])
  
  // Estado
  estado              String    @default("PENDIENTE") // PENDIENTE, CONCILIADO, DIFERENCIA, AJUSTE
  
  // Confianza de la conciliación automática
  confianza           Float?    // 0-100%
  
  // Ajuste (si aplica)
  montoAjuste         Float?
  observaciones       String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([conciliacionId])
  @@index([estado])
}

// ==================== FLUJO DE FAENA CON SUPERVISOR ====================

enum EstadoFlujoFaena {
  INICIADO              // Faena en proceso
  VERIFICACION          // En verificación de datos
  PENDIENTE_VISTO_BUENO // Esperando supervisor
  CONFIRMADO            // Visto bueno otorgado
  DATOS_SUBIDOS         // Datos subidos al sistema
  REPORTES_EMITIDOS     // Reportes generados
  ROMANEOS_ENVIADOS     // Romaneos enviados a clientes
  COMPLETADO            // Flujo completo
  ANULADO               // Anulado
}

model FlujoFaena {
  id                String          @id @default(cuid())
  fecha             DateTime        @default(now())
  listaFaenaId      String          @unique
  listaFaena        ListaFaena      @relation(fields: [listaFaenaId], references: [id])
  
  // Estados del flujo
  estado            EstadoFlujoFaena @default(INICIADO)
  
  // Verificación de datos
  datosVerificados  Boolean         @default(false)
  verificadorId     String?
  verificador       Operador?       @relation("VerificadorFlujo", fields: [verificadorId], references: [id])
  fechaVerificacion DateTime?
  
  // Confirmación de supervisor (Visto Bueno)
  vistoBueno        Boolean         @default(false)
  supervisorId      String?
  supervisor        Operador?       @relation("SupervisorFlujo", fields: [supervisorId], references: [id])
  fechaVistoBueno   DateTime?
  comentarioVistoBueno String?
  
  // Subida de datos
  datosSubidos      Boolean         @default(false)
  fechaSubida       DateTime?
  
  // Reportes y envío
  reportesEmitidos  Boolean         @default(false)
  fechaReportes     DateTime?
  romaneosEnviados  Boolean         @default(false)
  fechaEnvioRomaneos DateTime?
  
  // Observaciones
  observaciones     String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  historial         HistorialFlujoFaena[]
  
  @@index([estado])
  @@index([fecha])
}

// Historial de cambios de estado
model HistorialFlujoFaena {
  id            String   @id @default(cuid())
  flujoFaenaId  String
  flujoFaena    FlujoFaena @relation(fields: [flujoFaenaId], references: [id])
  
  estadoAnterior  String?
  estadoNuevo     String
  observaciones   String?
  
  operadorId    String?
  operador      Operador? @relation(fields: [operadorId], references: [id])
  fecha         DateTime @default(now())
  
  @@index([flujoFaenaId])
}

// ==================== MONEDAS Y COTIZACIONES ====================

model Moneda {
  id            String   @id @default(cuid())
  codigo        String   @unique // ARS, USD, EUR
  nombre        String   // Peso Argentino, Dólar Estadounidense, Euro
  simbolo       String   // $, US$, €
  esDefault     Boolean  @default(false)
  activa        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  cotizaciones  Cotizacion[]
  facturas      Factura[]
  pagos         Pago[]
}

model Cotizacion {
  id            String   @id @default(cuid())
  monedaId      String
  moneda        Moneda   @relation(fields: [monedaId], references: [id])
  fecha         DateTime @default(now())
  compra        Float    // Precio de compra
  venta         Float    // Precio de venta
  fuente        String?  // BCRA, Banco, Manual
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([monedaId, fecha])
}

// ==================== INTEGRACIÓN SIGICA ====================
// SIGICA: Sistema de Gestión de la Industria Cárnica Argentina
// Sistema oficial del SENASA para plantas faenadoras

model ConfiguracionSIGICA {
  id                String   @id @default(cuid())
  habilitado        Boolean  @default(false)
  urlServicio       String?  // URL del servicio SIGICA (homologación/producción)
  usuario           String?  // Usuario SIGICA
  password          String?  // Encriptado
  certificado       String?  // Ruta al certificado digital
  establecimiento   String?  // N° de establecimiento habilitado por SENASA
  ultimaSincronizacion DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Registro de envíos a SIGICA
model EnvioSIGICA {
  id              String          @id @default(cuid())
  tipo            TipoEnvioSIGICA
  fechaEnvio      DateTime        @default(now())
  
  // Datos enviados
  datosEnviados   String          // JSON con los datos completos
  cantidadRegistros Int           @default(0)
  
  // Respuesta
  estado          EstadoEnvioSIGICA @default(PENDIENTE)
  respuestaSIGICA String?         // JSON con la respuesta
  codigoTransaccion String?       // Código de transacción SIGICA
  mensajeError    String?
  
  // Referencias
  romaneoIds      String?         // IDs de romaneos enviados (JSON array)
  
  // Reintentos
  intentos        Int             @default(0)
  ultimoIntento   DateTime?
  
  operadorId      String?
  operador        Operador?       @relation(fields: [operadorId], references: [id])
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([tipo])
  @@index([estado])
  @@index([fechaEnvio])
}

enum TipoEnvioSIGICA {
  ROMANEO          // Envío de romaneo/faena
  STOCK_CAMARA     // Actualización de stock
  MOVIMIENTO       // Movimiento de mercadería
  DESPACHO         // Despacho de productos
}

enum EstadoEnvioSIGICA {
  PENDIENTE
  ENVIANDO
  EXITOSO
  ERROR
  REINTENTAR
}

// Stock de Cámara para SIGICA
model StockCamaraSIGICA {
  id            String   @id @default(cuid())
  camaraId      String
  camara        Camara   @relation(fields: [camaraId], references: [id])
  
  // Datos para SIGICA
  codigoSIGICA  String?  // Código asignado por SIGICA
  ultimaActualizacion DateTime @default(now())
  
  // Totales
  totalMedias   Int      @default(0)
  totalKg       Float    @default(0)
  
  // Por especie
  bovinosMedias Int      @default(0)
  bovinosKg     Float    @default(0)
  equinosMedias Int      @default(0)
  equinosKg     Float    @default(0)
  
  // Remanentes (productos que quedaron de procesamientos anteriores)
  remanenteKg   Float    @default(0)
  
  sincronizado  Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([camaraId])
}
