generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ConfiguracionFrigorifico {
  id                    String   @id @default(cuid())
  nombre                String   @default("Solemar Alimentaria")
  direccion             String?
  numeroEstablecimiento String?
  cuit                  String?
  numeroMatricula       String?
  logo                  String?
  emailHost             String?
  emailPuerto           Int?     @default(587)
  emailUsuario          String?
  emailPassword         String?
  emailHabilitado       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Corral {
  id                 String             @id @default(cuid())
  nombre             String             @unique
  capacidad          Int                @default(0)
  observaciones      String?
  activo             Boolean            @default(true)
  stockBovinos       Int                @default(0)
  stockEquinos       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  movimientosDestino MovimientoCorral[] @relation("CorralDestino")
  movimientosOrigen  MovimientoCorral[] @relation("CorralOrigen")
  tropas             Tropa[]
}

model Camara {
  id                 String             @id @default(cuid())
  nombre             String             @unique
  tipo               TipoCamara         @default(FAENA)
  capacidad          Int                @default(0)
  observaciones      String?
  activo             Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  mediasRes          MediaRes[]
  movimientosDestino MovimientoCamara[] @relation("CamaraDestino")
  movimientosOrigen  MovimientoCamara[] @relation("CamaraOrigen")
  stockMedias        StockMediaRes[]
}

model Tipificador {
  id        String    @id @default(cuid())
  nombre    String
  apellido  String
  numero    String?
  matricula String    @unique
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  romaneos  Romaneo[]
}

model Producto {
  id                      String      @id @default(cuid())
  codigo                  String
  nombre                  String
  nombreReportes          String?
  especie                 Especie
  codigoTipificacion      String?
  codigoTipoTrabajo       String?
  codigoTransporte        String?
  codigoDestino           String?
  tara                    Float?
  diasConservacion        Int?
  requiereTipificacion    Boolean     @default(false)
  tipoRotulo              TipoRotulo?
  precio                  Float?
  temperaturaConservacion String?
  apareceRendimiento      Boolean     @default(false)
  apareceStock            Boolean     @default(false)
  activo                  Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@unique([codigo, especie])
  @@index([especie])
}

model TipoMenudencia {
  id            String       @id @default(cuid())
  nombre        String       @unique
  activo        Boolean      @default(true)
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  menudencias   Menudencia[]
}

model Operador {
  id                      String              @id @default(cuid())
  nombre                  String
  usuario                 String              @unique
  password                String
  pin                     String?
  rol                     RolOperador         @default(OPERADOR)
  email                   String?
  activo                  Boolean             @default(true)
  puedePesajeCamiones     Boolean             @default(true)
  puedePesajeIndividual   Boolean             @default(true)
  puedeMovimientoHacienda Boolean             @default(true)
  puedeListaFaena         Boolean             @default(false)
  puedeRomaneo            Boolean             @default(false)
  puedeIngresoCajon       Boolean             @default(false)
  puedeMenudencias        Boolean             @default(false)
  puedeStock              Boolean             @default(false)
  puedeReportes           Boolean             @default(false)
  puedeCCIR               Boolean             @default(false)
  puedeFacturacion        Boolean             @default(false)
  puedeConfiguracion      Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  auditorias              Auditoria[]
  ccirs                   CCIR[]
  declaracionesJuradas    DeclaracionJurada[]
  facturas                Factura[]
  listasFaena             ListaFaena[]
  movimientosCamara       MovimientoCamara[]
  movimientosCorral       MovimientoCorral[]
  pesajesCamion           PesajeCamion[]
  pesajesIndividuales     PesajeIndividual[]
  romaneos                Romaneo[]
  tropasCreadas           Tropa[]
}

model Cliente {
  id                     String              @id @default(cuid())
  nombre                 String
  cuit                   String?             @unique
  direccion              String?
  telefono               String?
  email                  String?
  esProductor            Boolean             @default(false)
  esUsuarioFaena         Boolean             @default(false)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  declaracionesJuradas   DeclaracionJurada[]
  facturas               Factura[]
  tropasComoUsuarioFaena Tropa[]             @relation("UsuarioFaenaTropas")
  tropasComoProductor    Tropa[]             @relation("ProductorTropas")
}

model Transportista {
  id        String         @id @default(cuid())
  nombre    String
  cuit      String?        @unique
  direccion String?
  telefono  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  pesajes   PesajeCamion[]
}

model CodigoEspecie {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CodigoTransporte {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CodigoDestino {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CodigoTipoTrabajo {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CodigoTipificacion {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  especie   Especie
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tropa {
  id                        String                @id @default(cuid())
  numero                    Int                   @unique
  codigo                    String                @unique
  codigoSimplificado        String?
  productorId               String?
  usuarioFaenaId            String
  especie                   Especie               @default(BOVINO)
  dte                       String?
  guia                      String?
  cantidadCabezas           Int
  kgPie                     Float?
  kgGancho                  Float?
  rindePorcentaje           Float?
  fechaFaena                DateTime?
  precioServicioPorKg       Float?
  precioServicioConRecupero Float?
  totalServicio             Float?
  tasaInspVet               Float?
  arancelIpcva              Float?
  totalFactura              Float?
  numeroFactura             String?
  fechaFactura              DateTime?
  fechaPago                 DateTime?
  montoDepositado           Float?
  estadoPago                String?
  ventaHueso                Float?
  ventaDesperdicio          Float?
  ventaGrasa                Float?
  ventaCuero                Float?
  ventaGrasaDreasing        Float?
  ventaLavadito             Float?
  corralId                  String?
  estado                    EstadoTropa           @default(RECIBIDO)
  pesoBruto                 Float?
  pesoTara                  Float?
  pesoNeto                  Float?
  pesoTotalIndividual       Float?
  observaciones             String?
  fechaRecepcion            DateTime              @default(now())
  operadorId                String?
  pesajeCamionId            String?               @unique
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  animales                  Animal[]
  listasFaena               ListaFaenaTropa[]
  pesajeCamion              PesajeCamion?         @relation(fields: [pesajeCamionId], references: [id])
  operador                  Operador?             @relation(fields: [operadorId], references: [id])
  corral                    Corral?               @relation(fields: [corralId], references: [id])
  usuarioFaena              Cliente               @relation("UsuarioFaenaTropas", fields: [usuarioFaenaId], references: [id])
  productor                 Cliente?              @relation("ProductorTropas", fields: [productorId], references: [id])
  tiposAnimales             TropaAnimalCantidad[]

  @@index([especie])
  @@index([estado])
  @@index([fechaRecepcion])
}

model TropaAnimalCantidad {
  id         String     @id @default(cuid())
  tropaId    String
  tipoAnimal TipoAnimal
  cantidad   Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  tropa      Tropa      @relation(fields: [tropaId], references: [id], onDelete: Cascade)

  @@unique([tropaId, tipoAnimal])
}

model Animal {
  id               String            @id @default(cuid())
  tropaId          String
  numero           Int
  codigo           String            @unique
  caravana         String?
  tipoAnimal       TipoAnimal
  raza             String?
  pesoVivo         Float?
  estado           EstadoAnimal      @default(RECIBIDO)
  corralId         String?
  fechaBaja        DateTime?
  motivoBaja       String?
  pesoBaja         Float?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tropa            Tropa             @relation(fields: [tropaId], references: [id])
  asignacionGarron AsignacionGarron?
  pesajeIndividual PesajeIndividual?

  @@unique([tropaId, numero])
  @@index([estado])
}

model MovimientoCorral {
  id              String    @id @default(cuid())
  tropaId         String?
  animalId        String?
  corralOrigenId  String?
  corralDestinoId String
  cantidad        Int       @default(1)
  especie         Especie?
  observaciones   String?
  operadorId      String?
  fecha           DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  operador        Operador? @relation(fields: [operadorId], references: [id])
  corralDestino   Corral    @relation("CorralDestino", fields: [corralDestinoId], references: [id])
  corralOrigen    Corral?   @relation("CorralOrigen", fields: [corralOrigenId], references: [id])

  @@index([fecha])
}

model PesajeCamion {
  id              String           @id @default(cuid())
  tipo            TipoPesajeCamion @default(INGRESO_HACIENDA)
  numeroTicket    Int              @unique
  patenteChasis   String
  patenteAcoplado String?
  choferNombre    String?
  choferDni       String?
  transportistaId String?
  destino         String?
  remito          String?
  factura         String?
  precintos       String?
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  observaciones   String?
  estado          EstadoPesaje     @default(ABIERTO)
  operadorId      String?
  fecha           DateTime         @default(now())
  fechaTara       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  operador        Operador?        @relation(fields: [operadorId], references: [id])
  transportista   Transportista?   @relation(fields: [transportistaId], references: [id])
  tropa           Tropa?

  @@index([tipo])
  @@index([estado])
  @@index([fecha])
}

model PesajeIndividual {
  id            String    @id @default(cuid())
  animalId      String    @unique
  peso          Float
  caravana      String?
  observaciones String?
  operadorId    String?
  fecha         DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  operador      Operador? @relation(fields: [operadorId], references: [id])
  animal        Animal    @relation(fields: [animalId], references: [id])

  @@index([fecha])
}

model ListaFaena {
  id            String             @id @default(cuid())
  fecha         DateTime           @default(now())
  estado        EstadoListaFaena   @default(ABIERTA)
  cantidadTotal Int                @default(0)
  supervisorId  String?
  fechaCierre   DateTime?
  observaciones String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  asignaciones  AsignacionGarron[]
  supervisor    Operador?          @relation(fields: [supervisorId], references: [id])
  tropas        ListaFaenaTropa[]

  @@index([fecha])
  @@index([estado])
}

model ListaFaenaTropa {
  id           String     @id @default(cuid())
  listaFaenaId String
  tropaId      String
  cantidad     Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tropa        Tropa      @relation(fields: [tropaId], references: [id])
  listaFaena   ListaFaena @relation(fields: [listaFaenaId], references: [id], onDelete: Cascade)

  @@unique([listaFaenaId, tropaId])
}

model AsignacionGarron {
  id           String     @id @default(cuid())
  listaFaenaId String
  garron       Int
  animalId     String     @unique
  numeroAnimal Int
  horaIngreso  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  animal       Animal     @relation(fields: [animalId], references: [id])
  listaFaena   ListaFaena @relation(fields: [listaFaenaId], references: [id])

  @@unique([listaFaenaId, garron])
  @@index([garron])
}

model Romaneo {
  id                  String           @id @default(cuid())
  listaFaenaId        String?
  fecha               DateTime         @default(now())
  garron              Int
  tropaCodigo         String?
  tropaId             String?
  numeroAnimal        Int?
  tipoAnimal          TipoAnimal?
  raza                String?
  caravana            String?
  pesoVivo            Float?
  denticion           Int?
  categoria           CategoriaBovino?
  tipificacion        TipificacionRes?
  grasaCobertura      GrasaCobertura?
  conformacion        Conformacion?
  colorGrasa          ColorGrasa?
  madurez             String?
  clasificacionFaena  String?
  tipificadorId       String?
  pesoMediaIzq        Float?
  pesoMediaDer        Float?
  pesoTotal           Float?
  rinde               Float?
  destinoId           String?
  transporteId        String?
  tipoTrabajoId       String?
  codigoEAN128        String?
  estado              EstadoRomaneo    @default(PENDIENTE)
  supervisorId        String?
  fechaConfirmacion   DateTime?
  emailEnviado        Boolean          @default(false)
  sincronizado        Boolean          @default(true)
  fechaSincronizacion DateTime?
  operadorId          String?
  observaciones       String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  mediasRes           MediaRes[]
  operador            Operador?        @relation(fields: [operadorId], references: [id])
  tipificador         Tipificador?     @relation(fields: [tipificadorId], references: [id])

  @@index([fecha])
  @@index([garron])
  @@index([estado])
  @@index([tropaCodigo])
}

model MediaRes {
  id               String         @id @default(cuid())
  romaneoId        String
  lado             LadoMedia
  peso             Float
  sigla            SiglaMedia     @default(A)
  codigo           String         @unique
  codigoBarras     String?
  fechaFaena       DateTime       @default(now())
  fechaVencimiento DateTime?
  numeroRotulo     Int?
  vecesImpreso     Int            @default(0)
  ultimaImpresion  DateTime?
  estado           EstadoMediaRes @default(EN_CAMARA)
  camaraId         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  camara           Camara?        @relation(fields: [camaraId], references: [id])
  romaneo          Romaneo        @relation(fields: [romaneoId], references: [id])

  @@unique([romaneoId, lado, sigla])
  @@index([estado])
  @@index([codigo])
}

model StockMediaRes {
  id           String   @id @default(cuid())
  camaraId     String
  tropaCodigo  String?
  especie      Especie
  cantidad     Int      @default(0)
  pesoTotal    Float    @default(0)
  fechaIngreso DateTime @default(now())
  updatedAt    DateTime @updatedAt
  camara       Camara   @relation(fields: [camaraId], references: [id])

  @@unique([camaraId, tropaCodigo, especie])
}

model MovimientoCamara {
  id              String    @id @default(cuid())
  camaraOrigenId  String?
  camaraDestinoId String?
  producto        String?
  cantidad        Int?
  peso            Float?
  tropaCodigo     String?
  mediaResId      String?
  operadorId      String?
  observaciones   String?
  fecha           DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  operador        Operador? @relation(fields: [operadorId], references: [id])
  camaraDestino   Camara?   @relation("CamaraDestino", fields: [camaraDestinoId], references: [id])
  camaraOrigen    Camara?   @relation("CamaraOrigen", fields: [camaraOrigenId], references: [id])

  @@index([fecha])
}

model Menudencia {
  id                  String         @id @default(cuid())
  tipoMenudenciaId    String
  tropaCodigo         String?
  pesoIngreso         Float?
  pesoElaborado       Float?
  numeroBolsa         Int?
  cantidadBolsas      Int?
  operadorElaboracion String?
  fechaIngreso        DateTime       @default(now())
  fechaElaboracion    DateTime?
  rotuloImpreso       Boolean        @default(false)
  observaciones       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  tipoMenudencia      TipoMenudencia @relation(fields: [tipoMenudenciaId], references: [id])

  @@index([tropaCodigo])
  @@index([fechaIngreso])
}

model Auditoria {
  id           String    @id @default(cuid())
  operadorId   String?
  modulo       String
  accion       String
  entidad      String
  entidadId    String?
  descripcion  String
  datosAntes   String?
  datosDespues String?
  fecha        DateTime  @default(now())
  ip           String?
  operador     Operador? @relation(fields: [operadorId], references: [id])

  @@index([modulo])
  @@index([fecha])
}

model Numerador {
  id           String   @id @default(cuid())
  nombre       String   @unique
  ultimoNumero Int      @default(0)
  anio         Int?
  updatedAt    DateTime @updatedAt
}

model CCIR {
  id                    String     @id @default(cuid())
  numeroCertificado     String     @unique
  fechaEmision          DateTime   @default(now())
  producto              String
  cantidad              Float
  lote                  String?
  paisDestino           String
  puertoDestino         String?
  numeroEstablecimiento String?
  nombreEstablecimiento String?
  cuitEstablecimiento   String?
  nombreImportador      String?
  direccionImportador   String?
  numeroContenedor      String?
  matriculaTransporte   String?
  numeroPrecintos       String?
  observaciones         String?
  estado                EstadoCCIR @default(EMITIDO)
  operadorId            String?
  fechaImpresion        DateTime?
  vecesImpreso          Int        @default(0)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  operador              Operador?  @relation(fields: [operadorId], references: [id])

  @@index([fechaEmision])
  @@index([estado])
  @@index([paisDestino])
}

model DeclaracionJurada {
  id                 String                  @id @default(cuid())
  numeroDeclaracion  String                  @unique
  fecha              DateTime                @default(now())
  productorId        String?
  nombreProductor    String
  cuitProductor      String?
  direccionProductor String?
  procedencia        String?
  especie            Especie                 @default(BOVINO)
  cantidadCabezas    Int
  numeroTropa        String?
  numeroLote         String?
  numeroDTE          String?
  numeroGuia         String?
  declaracionSanidad String?
  procedenciaLibre   Boolean                 @default(true)
  observaciones      String?
  estado             EstadoDeclaracionJurada @default(ACTIVA)
  operadorId         String?
  fechaImpresion     DateTime?
  vecesImpreso       Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  operador           Operador?               @relation(fields: [operadorId], references: [id])
  productor          Cliente?                @relation(fields: [productorId], references: [id])

  @@index([fecha])
  @@index([estado])
  @@index([especie])
}

model Factura {
  id             String           @id @default(cuid())
  numero         String           @unique
  numeroInterno  Int
  clienteId      String
  fecha          DateTime         @default(now())
  fechaEmision   DateTime?
  fechaPago      DateTime?
  subtotal       Float            @default(0)
  iva            Float            @default(0)
  total          Float            @default(0)
  estado         EstadoFactura    @default(PENDIENTE)
  observaciones  String?
  condicionVenta String?
  remito         String?
  operadorId     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  detalles       DetalleFactura[]
  operador       Operador?        @relation(fields: [operadorId], references: [id])
  cliente        Cliente          @relation(fields: [clienteId], references: [id])

  @@index([numero])
  @@index([clienteId])
  @@index([estado])
  @@index([fecha])
}

model DetalleFactura {
  id             String              @id @default(cuid())
  facturaId      String
  tipoProducto   TipoProductoFactura
  descripcion    String
  cantidad       Float               @default(1)
  unidad         String              @default("KG")
  precioUnitario Float               @default(0)
  subtotal       Float               @default(0)
  tropaCodigo    String?
  garron         Int?
  mediaResId     String?
  pesoKg         Float?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  factura        Factura             @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@index([facturaId])
  @@index([tipoProducto])
}

model ConfiguracionBalanza {
  id                   String    @id @default(cuid())
  nombre               String    @unique
  tipoConexion         String
  puerto               String?
  baudRate             Int?      @default(9600)
  dataBits             Int?      @default(8)
  parity               String?   @default("none")
  stopBits             Int?      @default(1)
  ip                   String?
  puertoTcp            Int?
  protocolo            String    @default("CONTINUO")
  tiempoEstabilizacion Int       @default(3)
  pesoMinimo           Float     @default(0)
  pesoMaximo           Float     @default(1000)
  activo               Boolean   @default(true)
  ultimoTest           DateTime?
  estadoConexion       String    @default("DESCONECTADO")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ConfiguracionImpresora {
  id               String          @id @default(cuid())
  nombre           String          @unique
  tipo             String
  tipoConexion     String
  ip               String?
  puertoRed        Int?
  puertoSerial     String?
  anchoEtiqueta    Int             @default(100)
  altoEtiqueta     Int             @default(150)
  velocidad        Int             @default(2)
  densidad         Int             @default(8)
  plantillaZpl     String?
  activo           Boolean         @default(true)
  esPredeterminada Boolean         @default(false)
  ultimoTest       DateTime?
  estadoConexion   String          @default("DESCONECTADO")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  colasImpresion   ColaImpresion[]
}

model PlantillaRotulo {
  id             String          @id @default(cuid())
  nombre         String          @unique
  descripcion    String?
  tipo           String
  ancho          Int             @default(100)
  alto           Int             @default(150)
  campos         String
  plantillaZpl   String?
  plantillaHtml  String?
  tipoCodigo     String          @default("CODE128")
  incluirCodigo  Boolean         @default(true)
  posicionX      Int             @default(10)
  posicionY      Int             @default(50)
  alturaCodigo   Int             @default(30)
  destinos       String?
  activo         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  colasImpresion ColaImpresion[]
}

model ColaImpresion {
  id             String                  @id @default(cuid())
  tipoDocumento  String
  entidadId      String?
  datos          String
  plantillaId    String?
  impresoraId    String?
  estado         String                  @default("PENDIENTE")
  intentos       Int                     @default(0)
  error          String?
  fechaCreacion  DateTime                @default(now())
  fechaImpresion DateTime?
  impresora      ConfiguracionImpresora? @relation(fields: [impresoraId], references: [id])
  plantilla      PlantillaRotulo?        @relation(fields: [plantillaId], references: [id])

  @@index([estado])
  @@index([fechaCreacion])
}

model ColaSincronizacion {
  id                  String    @id @default(cuid())
  operacion           String
  entidad             String
  entidadId           String?
  datos               String
  estado              String    @default("PENDIENTE")
  intentos            Int       @default(0)
  error               String?
  fechaCreacion       DateTime  @default(now())
  fechaSincronizacion DateTime?

  @@index([estado])
  @@index([entidad])
  @@index([fechaCreacion])
}

